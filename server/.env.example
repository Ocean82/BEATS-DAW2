# Node.js API (default port 3001)
PORT=3001
# Base URL for API links returned to the client (e.g. stem download URLs). Omit for localhost:PORT.
# PUBLIC_API_URL=http://localhost:3001

# Python stem service (default port 5000)
PYTHON_SERVICE_URL=http://localhost:5000
PYTHON_SERVICE_PORT=5000

# Database (optional for now)
DATABASE_URL="file:./dev.db"

# AWS/R2 (for future EC2 deployment)
# R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
# R2_ACCESS_KEY=your_access_key
# R2_SECRET_KEY=your_secret_key
# R2_BUCKET_NAME=beats-daw-audio
# R2_PUBLIC_URL=https://your-public-url.com
